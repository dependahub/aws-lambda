{
  "name": "@dependahub/aws-lambda",
  "version": "1.1.2",
  "description": "AWS Lambda 操作モジュール",
  "license": "MIT",
  "author": "DependaHub",
  "types": "@types/index.d.ts",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "lint": "xo",
    "format": "xo --fix",
    "test": "xo && node --test",
    "build": "rm -rf @types && tsc",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1000.0",
    "@aws-sdk/credential-providers": "^3.1000.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.161",
    "@types/node": "^25.3.3",
    "typescript": "^5.9.3",
    "xo": "^1.2.3"
  },
  "homepage": "https://github.com/dependahub/aws-lambda#readme",
  "bugs": {
    "url": "https://github.com/dependahub/aws-lambda/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dependahub/aws-lambda.git"
  },
  "keywords": [
    "aws",
    "lambda"
  ],
  "xo": {
    "ignore": [
      "@types"
    ],
    "rules": {
      "capitalized-comments": "off"
    }
  }
}
